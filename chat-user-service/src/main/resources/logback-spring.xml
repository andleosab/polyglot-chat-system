<?xml version="1.0" encoding="UTF-8"?>                                           
<configuration>
	<include resource="org/springframework/boot/logging/logback/defaults.xml" />
	<!-- 
	<property name="LOG_FILE" value="${LOG_FILE:-${LOG_PATH:-${LOG_TEMP:-${java.io.tmpdir:-/tmp}}}/service.log}"/>
	-->
	<property name="LOG_FILE" value="${LOG_FILE:-./logs/service.log}"/>
	<include resource="org/springframework/boot/logging/logback/file-appender.xml" />
	<include resource="org/springframework/boot/logging/logback/console-appender.xml" />


	<!-- turn on to see requests/responses -->
	<!--
	<logger name="reactor.netty.http.client" level="DEBUG"/>
	-->

	<logger name="net.schmizz.sshj" level="WARN"/>
	<logger name="org.apache.kafka.clients.NetworkClient" level="ERROR"/>
	
	<!-- turn on to see requests/responses for reactive webclient -->
	<!-- -->
	<logger name="org.apache.hc.client5.http.wire" level="${HTTP_WIRE_LOGGING_LEVEL:-${DEFAULT_LOGGING_LEVEL:-INFO}}"/>
	<logger name="org.apache.hc.client5.http.headers" level="${HTTP_WIRE_LOGGING_LEVEL:-${DEFAULT_LOGGING_LEVEL:-INFO}}"/>
	
	<!-- 
	<logger name="org.apache.http.wire" level="${HTTP_WIRE_LOGGING_LEVEL:-${DEFAULT_LOGGING_LEVEL:-DEBUG}}"/>
	<logger name="org.apache.http.headers" level="${HTTP_WIRE_LOGGING_LEVEL:-${DEFAULT_LOGGING_LEVEL:-DEBUG}}"/>
	-->
	<!-- Spring transactions  -->
	<!--
	<logger name="org.springframework.orm.jpa" level="INFO" />
	<logger name="org.springframework.transaction" level="TRACE" />
   	<logger name="org.hibernate.engine.transaction.internal.TransactionImpl" level="DEBUG" />
   	-->
	
	<logger name="org.demo" level="DEBUG" />
	<logger name="org.apache.http" level="${DEFAULT_LOGGING_LEVEL:-INFO}" />
	<logger name="org.springframework.security" level="${SPRING_SECURITY_LOGGING_LEVEL:-${DEFAULT_LOGGING_LEVEL:-INFO}}"/>
	<logger name="org.mongodb" level="${MONGO_LOGGING_LEVEL:-INFO}"/>
	<logger name="org.springframework.data.mongodb.core.MongoTemplate" level="${MONGO_LOGGING_LEVEL:-INFO}"/>
	<logger name="org.hibernate.SQL" level="DEBUG"/>
	<logger name="org.hibernate.type" level="DEBUG"/>
	<logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>
	<logger name="io.swagger.models.parameters" level="OFF"/> 
	<logger name="com.zaxxer.hikari.HikariConfig" level="DEBUG"/>
	<logger name="com.hazelcast" level="WARN"/>
	<logger name="freemarker" level="INFO"/> 
	<logger name="org.springframework" level="INFO"/>
	
	<!--<logger name="org.springframework.web.filter.CommonsRequestLoggingFilter" level="DEBUG"/>-->

	<root level="${LOGBACK_ROOT_LEVEL:-INFO}">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="FILE" />
	</root>
</configuration>
